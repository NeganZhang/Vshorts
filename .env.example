# ─── Server ────────────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Supabase (auth) ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM providers ─────────────────────────────────────────────────────
# CutClaw (via LiteLLM) and the script / scene generators all read this.
ANTHROPIC_API_KEY=

# Optional: override the model CutClaw uses. LiteLLM-prefixed model names,
# e.g. anthropic/claude-sonnet-4-5 or openai/gpt-4o.
# CUTCLAW_MODEL=anthropic/claude-sonnet-4-5

# ─── Python interpreter override ───────────────────────────────────────
# The server auto-detects server/python/.venv/Scripts/python.exe on Windows
# (or .venv/bin/python on POSIX). Set this only if you want to use a
# different Python — e.g. a system install or a conda env.
# PYTHON=C:/path/to/python.exe

# ─── FFmpeg binary override ────────────────────────────────────────────
# Only needed if ffmpeg isn't on PATH. Example for a D:\Tools install:
# FFMPEG=D:/Tools/ffmpeg/bin/ffmpeg.exe

# ─── Whisper model size for caption fallback ───────────────────────────
# tiny | base | small | medium | large-v3. base is a good CPU default.
# VSHORT_WHISPER_MODEL=base

# ─── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
