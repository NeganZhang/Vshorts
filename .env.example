# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Supabase auth
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional AI providers for script/storyboard generation
ANTHROPIC_API_KEY=
KIMI_API_KEY=
# Storyboard images: leave DOUBAO_API_KEY blank and set GEMINI_API_KEY to use
# Gemini ("image 2.0" / nano banana). Gemini is international — set HTTPS_PROXY
# if you are in mainland China.
DOUBAO_API_KEY=
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-image
# HTTPS_PROXY=http://127.0.0.1:7890

# ─── Image-to-video (Seedance on Volcano Ark, 火山方舟) ───────────────────
# Domestic API — does NOT use HTTPS_PROXY (the service forces a no-proxy dispatcher).
# Without ARK_API_KEY the render pipeline produces mock placeholder clips (no spend).
ARK_API_KEY=
ARK_VIDEO_MODEL=doubao-seedance-2-0-260128
ARK_VIDEO_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
ARK_VIDEO_RESOLUTION=1080p
ARK_CLIP_SECONDS=5
ARK_RENDER_CONCURRENCY=1
ARK_VIDEO_TIMEOUT_MS=360000
# Cost caps (enforced server-side)
MAX_RENDER_SCENES=8
MAX_TOTAL_SECONDS=80

# Media tool overrides
# Only needed when ffmpeg / ffprobe are not on PATH.
# FFMPEG=D:/Tools/ffmpeg/bin/ffmpeg.exe
# FFPROBE=D:/Tools/ffmpeg/bin/ffprobe.exe

# HyperFrames browser override
# Only needed when HyperFrames cannot find Chrome automatically.
# HYPERFRAMES_BROWSER_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
